NEXT_PUBLIC_CONVEX_URL=
CONVEX_SELF_HOSTED_URL=
CONVEX_SELF_HOSTED_ADMIN_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
# RS256 private key (PKCS8 PEM, newlines escaped as \n) used to sign Convex JWTs.
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# Public half is served at /api/auth/jwks.
# The Convex deployment needs matching env vars (npx convex env set):
#   AUTH_JWT_ISSUER = this NEXTAUTH_URL
#   AUTH_JWKS_URL   = URL (or data: URI) of the JWKS reachable from the Convex backend
CONVEX_AUTH_PRIVATE_KEY=